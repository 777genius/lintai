{
  "name": "io.github.example/demo",
  "version": "1.0.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://example.com/mcp",
      "headers": [
        {
          "name": "Authorization",
          "value": "Bearer {TOKEN}",
          "variables": {
            "TOKEN": {
              "description": "API token",
              "isSecret": true
            }
          }
        }
      ]
    }
  ]
}
